# Dependencias
node_modules/
venv/
__pycache__/

# IDEs
.vscode/
.idea/
.DS_Store

# Ambiente local (overrides - NAO confundir com config/.env que E versionado)
.env
!config/.env
.env.local
*.env.local

# Builds (Electron)
dist/
build/
*.exe

# Backups de producao (dados sensiveis)
backups/*.sql
backups/*.sql.gz
backups/*.dump
!backups/.gitkeep

# Logs
*.log
logs/

# Debug screenshots (gerados pelo scraper)
debug/

# Terminal logs (sessoes Claude Code - rotacao automatica 60 dias)
/terminal_logs/
