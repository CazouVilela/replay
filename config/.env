# ============================================================
# CREDENCIAIS: Fonte central em /home/cazouvilela/credenciais/
# NUNCA hardcodar credenciais aqui. Use referencia central.
# Loader bash: source /home/cazouvilela/credenciais/load-credentials.sh
# Loader node: require('/home/cazouvilela/credenciais/credentials.js')
# ============================================================
#
# Ambiente: PRODUCAO
# Projeto: replay
#
# ⚠️  ATENCAO: Este e o ambiente de producao com dados reais.
# ⚠️  Qualquer alteracao de schema/dados EXIGE backup previo.
# ⚠️  Qualquer deploy EXIGE commit previo e analise de impacto.

APP_ENV=prod
PREFIX=

# Banco de Dados (credenciais em /home/cazouvilela/credenciais/database/)
DB_NAME=replay
DB_HOST=localhost
DB_PORT=15432
DB_USER=prod_user
DB_PASSWORD=ALTERAR_OU_REFERENCIAR_CREDENCIAL_CENTRAL

# Servidor
BACKEND_PORT=5204
FRONTEND_PORT=3204
API_URL=http://localhost:5204

# Services (systemd)
SERVICE_BACKEND=replay-backend
SERVICE_FRONTEND=replay-frontend
